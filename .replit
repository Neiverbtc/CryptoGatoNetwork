modules = ["nodejs-20"]

[nix]
channel = "stable-24_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "CryptoGato Development Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test_cryptogato"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Install Dependencies"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Install Hardhat Dependencies"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "CryptoGato DApp Server"

[[workflows.workflow]]
name = "CryptoGato Development Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx hardhat compile --config hardhat.config.js"

[[workflows.workflow]]
name = "test_cryptogato"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /tmp && npm install && npm test"

[[workflows.workflow]]
name = "Install Dependencies"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm install --legacy-peer-deps"

[[workflows.workflow]]
name = "Install Hardhat Dependencies"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm install --save-dev \"@nomicfoundation/hardhat-chai-matchers@^2.0.0\" \"@nomicfoundation/hardhat-ethers@^3.0.0\" \"@nomicfoundation/hardhat-ignition-ethers@^0.15.0\" \"@nomicfoundation/hardhat-network-helpers@^1.0.0\" \"@nomicfoundation/hardhat-verify@^2.0.0\" \"@typechain/ethers-v6@^0.5.0\" \"@typechain/hardhat@^9.0.0\" \"@types/chai@^4.2.0\" \"@types/mocha@>=9.1.0\" \"ts-node@>=8.0.0\" \"typechain@^8.3.0\" \"typescript@>=4.5.0\" --legacy-peer-deps"

[[workflows.workflow]]
name = "CryptoGato DApp Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx vite --port 5000 --host 0.0.0.0"
waitForPort = 5000

[deployment]
run = ["sh", "-c", "npx hardhat compile --config hardhat.config.js"]

[[ports]]
localPort = 5000
externalPort = 80
